# ---- ECHO-SRE configuration (all optional; copy to .env) ----

# Path to the ordered provider registry used by the inference gateway.
ECHO_SRE_PROVIDERS_FILE=config/providers.yaml

# Which observability backend the agent investigates: synthetic | prometheus
ECHO_SRE_BACKEND=synthetic

# Use a real in-process MCP client round-trip for tool calls (CLI).
# The HTTP API defaults to direct in-process tools for throughput.
ECHO_SRE_USE_MCP=true

# Prometheus metrics exporter port (gateway + agent metrics).
ECHO_SRE_METRICS_PORT=9090

ECHO_SRE_LOG_LEVEL=INFO

# CORS origins allowed to call the streaming API (comma-separated).
# Includes the hosted portfolio so the SRE mode can stream from the browser.
ECHO_SRE_CORS_ORIGINS=https://hello-sharon.dev,http://localhost:5173

# ---- Provider API keys (referenced by name from the providers file) ----
# Leave blank to skip a provider. If none are usable, ECHO-SRE falls back to a
# deterministic offline mock model so the demo still runs.
GEMINI_API_KEY=
OPENAI_API_KEY=
TOGETHER_API_KEY=
GROQ_API_KEY=
# vLLM accepts any non-empty string.
VLLM_API_KEY=EMPTY

# ---- Production observability backend (only when ECHO_SRE_BACKEND=prometheus) ----
ECHO_SRE_PROM_URL=
ECHO_SRE_LOKI_URL=
ECHO_SRE_ALERTMANAGER_URL=
